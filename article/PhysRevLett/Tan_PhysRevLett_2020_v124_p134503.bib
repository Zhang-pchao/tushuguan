@article{Tan_PhysRevLett_2020_v124_p134503,
  title        = {{How Bulk Nanobubbles Might Survive}},
  author       = {Beng Hau Tan and Hongjie An and Claus-Dieter Ohl},
  year         = 2020,
  journal      = {Phys. Rev. Lett.},
  volume       = 124,
  number       = 13,
  pages        = 134503,
  doi          = {10.1103/physrevlett.124.134503},
  abstract     = {
    The existence of bulk nanobubbles has long been regarded with scepticism,
    due to the limitations of experimental techniques and the widespread
    assumption that spherical bubbles cannot achieve stable equilibrium. We
    develop a model for the stability of bulk nanobubbles based on the
    experimental observation that the zeta potential of spherical bubbles
    abruptly diverges from the planar value below
    10{\,}{\,}{\ensuremath{\mu}}m. Our calculations recover three persistently
    reported-but disputed-properties of bulk nanobubbles: that they stabilize
    at a typical radius of {\ensuremath{\sim}}100{\,}{\,}nm, that this radius
    is bounded below 1{\,}{\,}{\ensuremath{\mu}}m, and that it increases with
    ionic concentration.
  },
}
