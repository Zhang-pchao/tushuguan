@article{Zhang_JMaterChemA_2026_v14_p7109,
  title        = {
    {Solvent effect on the electrocatalytic nitrogen reduction reaction: a deep
    potential molecular dynamics simulation with enhanced sampling for the case
    of the ruthenium single atom catalyst}
  },
  author       = {Bowen Zhang and Pengchao Zhang and Xuefei Xu},
  year         = 2026,
  journal      = {J. Mater. Chem. A},
  volume       = 14,
  number       = 12,
  pages        = {7109--7120},
  doi          = {10.1039/D5TA09029F},
  abstract     = {
    Deep potential molecular dynamics simulations with enhanced sampling were
    employed to investigate the solvent effect on the electrocatalytic NRR and
    obtained the energy barrier of the rate- determining step consistent with
    experiments.
  },
}
