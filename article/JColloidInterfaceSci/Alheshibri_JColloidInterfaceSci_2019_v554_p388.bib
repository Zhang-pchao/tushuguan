@article{Alheshibri_JColloidInterfaceSci_2019_v554_p388,
  title        = {
    {Does gas supersaturation by a chemical reaction produce bulk nanobubbles?}
  },
  author       = {
    Muidh Alheshibri and Marie Jehannin and Victoria A. Coleman and Vincent S.
    J. Craig
  },
  year         = 2019,
  journal      = {J. Colloid Interface Sci.},
  volume       = 554,
  pages        = {388--395},
  doi          = {10.1016/j.jcis.2019.07.016},
  abstract     = {
    Supersaturation of dissolved gas is the most commonly reported method for
    generating long-lived bulk nanobubbles. However, these reports are treated
    with skepticism because of the lack of techniques that directly show that
    these particles are gas filled bubbles. Therefore, this work has tested the
    hypothesis that supersaturation obtained by a chemical reaction produces
    long-lived nanosized bubbles in bulk using an established protocol that
    relies on evaluating the density of nanoparticles and measuring their
    response to external pressure.
  },
}
