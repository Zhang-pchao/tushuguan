@article{Reguera_JChemPhys_2003_v118_p340,
  title        = {{Phase transitions in systems small enough to be clusters}},
  author       = {D. Reguera and R. K. Bowles and Y. Djikaev and H. Reiss},
  year         = 2003,
  journal      = {J. Chem. Phys.},
  volume       = 118,
  number       = 1,
  pages        = {340--353},
  doi          = {10.1063/1.1524192},
  abstract     = {
    We analyze peculiarities of phase transitions in small systems. We focus on
    the formation of a tiny liquid drop in a small N,{\;}V,{\;}T system, and
    develop an {\textquotedblleft}extended modified liquid
    drop{\textquotedblright} model, which incorporates the effect of the
    fluctuations relevant for small systems. We compare the predictions for the
    p{\ensuremath{-}}v isotherms and the density profiles with the results of
    Monte-Carlo simulations of a Lennard-Jones system, and Density Functional
    Theory.
  },
}
