@article{Sviridov_ApplPhysLett_2015_v107_p123107,
  title        = {
    {Lowering of the cavitation threshold in aqueous suspensions of porous
    silicon nanoparticles for sonodynamic therapy applications}
  },
  author       = {
    A. P. Sviridov and L. A. Osminkina and A. L. Nikolaev and A. A. Kudryavtsev
    and A. N. Vasiliev and V. Yu. Timoshenko
  },
  year         = 2015,
  journal      = {Appl. Phys. Lett.},
  volume       = 107,
  number       = 12,
  pages        = 123107,
  doi          = {10.1063/1.4931728},
  abstract     = {
    A significant decrease of the cavitation threshold in aqueous suspensions
    of porous silicon nanoparticles (PSi NPs) with sizes about 100{\,}nm as
    compared with pure water was observed for ultrasound irradiation (USI) with
    therapeutic frequency (0.88 MHz) and intensities (about 1{\,}W/cm2). This
    effect is explained by porous morphology of PSi NPs, which promotes the
    nucleation of cavitation bubbles. In vitro experiments revealed a
    suppression of the proliferation of cancer cells with the introduced PSi
    NPs after exposure to USI related to the enhanced cavitation processes,
    which led to the cell destruction. The obtained results demonstrate that
    PSi NPs are prospective for applications as sonosensitizers in mild cancer
    therapy.
  },
}
