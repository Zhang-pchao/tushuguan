@article{Safonov_ColloidsSurfAPhysicochemEngAsp_2013_v436_p333,
  title        = {{Hydrogen nanobubbles in a water solution of dietary supplement}},
  author       = {V.L. Safonov and A.K. Khitrin},
  year         = 2013,
  journal      = {Colloids Surf. A: Physicochem. Eng. Asp.},
  volume       = 436,
  pages        = {333--336},
  doi          = {10.1016/j.colsurfa.2013.06.043},
  abstract     = {
    Using gas chromatography, proton nuclear magnetic resonance and qualitative
    experiments, we demonstrate that a water solution of dissolved dietary
    supplement, creating negative redox potential, contains invisible hydrogen
    nano-bubbles, which remain in the solution for several hours.
  },
}
